<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AuraNote" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/deep_navy</item>
        <item name="android:navigationBarColor">@color/deep_navy</item>
        <item name="android:windowBackground">@color/deep_navy</item>
    </style>

    <style name="Theme.AuraNote.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/deep_navy</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.AuraNote</item>
    </style>
</resources>
